def dagger_check(op1, op2):
	if op1[1][:2] == op2[1][:2]:

		if op1[0] == "T" and op2[0] == "TD":
			return True
		elif op1[0] == "TD" and op2[0] == "T":
			return True
		elif op1[0] == "S" and op2[0] == "SD":
			return True
		elif op1[0] == "SD" and op2[0] == "S":
			return True
		else:
			return False
	else :
		return False


