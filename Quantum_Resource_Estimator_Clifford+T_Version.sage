				elif gate[0] == "MM":
					if gate_str == "":
						gate_str += ("%s("%(gate[0]))
						for k in range(len(gate[1])-1):
							gate_str += ("%d,"%(gate[1][k]))
						gate_str += ("%d)"%gate[1][k+1])
					else:
						gate_str += (", %s("%(gate[0]))
						for k in range(len(gate[1])-1):
							gate_str += ("%d,"%(gate[1][k]))
						gate_str += ("%d)"%gate[1][k+1])
				else:
					if gate_str == "":
						gate_str += ("%s(%d)"%(gate[0],gate[1][0]))
					else:
						gate_str += (", %s(%d)"%(gate[0],gate[1][0]))

			print(gate_str)

		else:
			print("#----------- Layer: %d #--------------#"%(layer[0][3])) 
