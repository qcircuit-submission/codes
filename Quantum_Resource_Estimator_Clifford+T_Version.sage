				if gate[0] == "CNOT" :
					if gate_str == "":
						gate_str += ("%s(%d,%d)"%(gate[0],gate[1][0],gate[1][1]))
					else:
						gate_str += (", %s(%d,%d)"%(gate[0],gate[1][0],gate[1][1]))
				elif gate[0] == "MM":
